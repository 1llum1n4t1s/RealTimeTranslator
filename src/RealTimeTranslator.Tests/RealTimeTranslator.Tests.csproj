<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <PackageReference Include="MSTest" Version="4.2.3" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.7.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\RealTimeTranslator.Core\RealTimeTranslator.Core.csproj" />
    <!-- UI 側ヘルパー (SettingsViewModel.ComposeArgbHex / SplitArgbToRgbAndOpacity 等) のユニットテスト用
         (rere B2-001 対応)。 Avalonia 等の UI 依存を Tests に持ち込むが、 純粋関数の round-trip 検証のため許容。 -->
    <ProjectReference Include="..\RealTimeTranslator.UI\RealTimeTranslator.UI.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
  </ItemGroup>

  <ItemGroup>
    <!-- silero-vad 公式テスト wav (人声サンプル、 16kHz mono PCM16、 ~60秒)。
         SileroVadDetector が実音声で speech prob を返せるかの結合テスト用 (sr scalar 修正の検証)。
         ライセンス: MIT (snakers4/silero-vad リポジトリと同じ)。 -->
    <Content Include="Assets/test.wav" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
