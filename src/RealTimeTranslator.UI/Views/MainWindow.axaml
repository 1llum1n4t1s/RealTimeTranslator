<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RealTimeTranslator.UI.ViewModels"
        xmlns:converters="using:RealTimeTranslator.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="550"
        x:Class="RealTimeTranslator.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding VersionText, StringFormat='リアルタイム字幕翻訳 v{0}'}"
        Icon="avares://RealTimeTranslator.UI/Assets/app.ico"
        Width="750" Height="550"
        MinWidth="650" MinHeight="450"
        CanResize="False"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="32"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- ウィンドウ背景: アクリルブラー（Lhamiel と統一） -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    MaterialOpacity="0.85"
                    TintColor="{DynamicResource Color.Window}"
                    TintOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- メインコンテンツ。タイトルバー (32px) の下にレイアウトされるよう上 Margin を 36 に -->
        <Grid Margin="16,36,16,16">
        <!-- Loading Overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <ProgressBar Height="6" Margin="0,0,0,20" IsIndeterminate="True"/>
                <TextBlock Text="{Binding LoadingMessage}" FontSize="16"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="しばらくお待ちください..." FontSize="12"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           Foreground="{DynamicResource Brush.FG2}"/>
                <StackPanel Margin="0,20,0,0" IsVisible="{Binding IsDownloading}">
                    <TextBlock Text="{Binding DownloadStatus}" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <ProgressBar Height="6" Value="{Binding DownloadProgress}"
                                 Minimum="0" Maximum="100"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Main Content with Sidebar Tabs -->
        <TabControl Classes="sidebar"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

            <!-- ═══ Tab 1: メイン ═══ -->
            <TabItem Header="メイン">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="リアルタイム字幕翻訳" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="ゲームや動画の音声をリアルタイムで翻訳字幕に変換します"
                                       FontSize="12" Foreground="{DynamicResource Brush.FG2}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Process Selection -->
                        <HeaderedContentControl Header="対象アプリケーション">
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Processes}"
                                          SelectedItem="{Binding SelectedProcess}"
                                          PlaceholderText="プロセスを選択"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="1" Content="更新"
                                        Command="{Binding RefreshProcessesCommand}"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Status -->
                        <HeaderedContentControl Header="ステータス">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="処理遅延: " FontSize="12"
                                               Foreground="{DynamicResource Brush.FG2}"/>
                                    <TextBlock Text="{Binding ProcessingLatency, StringFormat=\{0:F0\}ms}"
                                               FontSize="12"/>
                                    <TextBlock Text="  |  翻訳遅延: " Margin="16,0,0,0" FontSize="12"
                                               Foreground="{DynamicResource Brush.FG2}"/>
                                    <TextBlock Text="{Binding TranslationLatency, StringFormat=\{0:F0\}ms}"
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- API キー未入力時の警告（IsApiKeyConfigured=false の時のみ表示） -->
                        <Border IsVisible="{Binding !IsApiKeyConfigured}"
                                Background="#33FFA500"
                                BorderBrush="#FFFFA500"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⚠" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="OpenAI API キーが未設定です。"/>
                                    <LineBreak/>
                                    <Run Text="上の「API設定」タブを開いて API キーを入力してください。" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 重大 API エラーバナー (Quota / InvalidApiKey / Forbidden) -->
                        <Border IsVisible="{Binding IsErrorBannerVisible}"
                                Background="#33FF4444"
                                BorderBrush="#FFFF4444"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,8,0,0">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="❌" FontSize="16"
                                           VerticalAlignment="Top" Margin="0,2,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="OpenAI API エラー" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding ErrorBannerMessage}"
                                               TextWrapping="Wrap" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="✕"
                                        Command="{Binding DismissErrorBannerCommand}"
                                        VerticalAlignment="Top" Padding="6,2"
                                        FontSize="11" Background="Transparent"
                                        ToolTip.Tip="バナーを閉じる"/>
                            </Grid>
                        </Border>

                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <Button Content="開始" Command="{Binding StartCommand}"
                                    IsEnabled="{Binding CanStart}" Width="140"/>
                            <Button Content="停止" Command="{Binding StopCommand}"
                                    IsEnabled="{Binding IsRunning}" Width="140" Margin="8,0,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 2: API設定 ═══ -->
            <TabItem Header="API設定" x:DataType="vm:MainViewModel">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SettingsVM}">
                    <StackPanel Margin="0,0,0,16" x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="OpenAI API設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- API Key -->
                        <HeaderedContentControl Header="APIキー">
                            <StackPanel>
                                <TextBox Text="{Binding ApiKey, Mode=TwoWay}"
                                         PasswordChar="*"
                                         PlaceholderText="sk-..."
                                         Margin="0,0,0,10"/>
                                <Button Content="接続テスト"
                                        Command="{Binding TestApiConnectionCommand}"
                                        IsEnabled="{Binding IsTestingApi, Converter={StaticResource InverseBoolConverter}}"
                                        Margin="0,0,0,8"/>
                                <TextBox Text="{Binding ApiTestResult, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="13"
                                         IsVisible="{Binding ApiTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- Output Language -->
                        <HeaderedContentControl Header="出力言語（翻訳先）">
                            <ComboBox ItemsSource="{Binding OutputLanguageOptions}"
                                      SelectedItem="{Binding SelectedOutputLanguage, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:OutputLanguageOption">
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 3: 表示設定 ═══ -->
            <TabItem Header="表示設定" x:DataType="vm:MainViewModel">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SettingsVM}">
                    <StackPanel Margin="0,0,0,16" x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="オーバーレイ表示設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- Font -->
                        <HeaderedContentControl Header="フォント">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                          ItemsSource="{Binding FontFamilies}"
                                          SelectedItem="{Binding SelectedFontFamily, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="サイズ"
                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding FontSizes}"
                                          SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                                          Width="100">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=\{0\}px}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Colors -->
                        <HeaderedContentControl Header="字幕カラー">
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="仮字幕色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding TextColorOptions}"
                                          SelectedItem="{Binding SelectedPartialTextColorOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="確定字幕色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding TextColorOptions}"
                                          SelectedItem="{Binding SelectedFinalTextColorOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="背景色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding BackgroundColorOptions}"
                                          SelectedItem="{Binding SelectedBackgroundColorOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Max Lines + Display Duration -->
                        <HeaderedContentControl Header="表示">
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="最大行数"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding MaxLinesList}"
                                          SelectedItem="{Binding SelectedMaxLines, Mode=TwoWay}"
                                          Width="100"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="表示時間"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding DisplayDurations}"
                                          SelectedItem="{Binding SelectedDisplayDuration, Mode=TwoWay}"
                                          Width="100"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=\{0\} 秒}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 4: バージョン ═══ -->
            <TabItem Header="バージョン">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,0,8,12">
                        <TextBlock Margin="4,0,0,4" FontSize="28" FontWeight="Bold"
                                   Text="リアルタイム字幕翻訳"/>
                        <TextBlock Margin="4,0,0,20" FontSize="14"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   Text="ゲームや動画の音声をリアルタイムで翻訳字幕に変換するデスクトップアプリ"/>

                        <!-- バージョン情報パネル -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Margin="0,0,12,0" VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="バージョン"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           VerticalAlignment="Center" FontSize="13"
                                           Text="{Binding VersionText}"/>
                                <Button Grid.Row="0" Grid.Column="2"
                                        Command="{Binding CheckForUpdateCommand}"
                                        Content="更新の確認" FontSize="12"
                                        IsEnabled="{Binding !IsCheckingUpdate}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                           Margin="0,6,0,0" FontSize="12"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           IsVisible="{Binding UpdateStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Text="{Binding UpdateStatusText}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- トラブルシュート: ログ / 設定フォルダ (rere P2 F-2 修正) -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="トラブルシュート用: ログ / 設定フォルダをエクスプローラで開きます。"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding OpenLogsFolderCommand}"
                                            Content="ログフォルダを開く" FontSize="12"/>
                                    <Button Command="{Binding OpenSettingsFolderCommand}"
                                            Content="設定フォルダを開く" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ご意見・ご要望 -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="不具合報告・ご要望は GitHub Issues へどうぞ。"
                                           TextWrapping="Wrap"/>
                                <Button Command="{Binding OpenFeedbackLinkCommand}"
                                        Content="GitHub Issues を開く" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- コピーライト -->
                        <Border Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6" FontSize="13" FontWeight="SemiBold"
                                           Text="コピーライト"/>
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="{Binding CopyrightText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
    </Panel>
</Window>
