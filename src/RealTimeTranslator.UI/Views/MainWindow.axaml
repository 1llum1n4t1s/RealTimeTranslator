<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RealTimeTranslator.UI.ViewModels"
        xmlns:models="using:RealTimeTranslator.Core.Models"
        xmlns:converters="using:RealTimeTranslator.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="800"
        x:Class="RealTimeTranslator.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding VersionText, StringFormat='リアルタイム字幕翻訳 v{0}'}"
        Icon="avares://RealTimeTranslator.UI/Assets/app.ico"
        Width="750" Height="800"
        MinWidth="650" MinHeight="450"
        CanResize="True"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="32"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:LevelMeterMaskWidthConverter x:Key="LevelMeterMaskWidthConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- ウィンドウ背景: アクリルブラー（Lhamiel と統一） -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    MaterialOpacity="0.85"
                    TintColor="{DynamicResource Color.Window}"
                    TintOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- メインコンテンツ。タイトルバー (32px) の下にレイアウトされるよう上 Margin を 36 に -->
        <Grid Margin="16,36,16,16">
        <!-- Loading Overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <ProgressBar Height="6" Margin="0,0,0,20" IsIndeterminate="True"/>
                <TextBlock Text="{Binding LoadingMessage}" FontSize="16"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="しばらくお待ちください..." FontSize="12"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           Foreground="{DynamicResource Brush.FG2}"/>
                <StackPanel Margin="0,20,0,0" IsVisible="{Binding IsDownloading}">
                    <TextBlock Text="{Binding DownloadStatus}" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <ProgressBar Height="6" Value="{Binding DownloadProgress}"
                                 Minimum="0" Maximum="100"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Main Content with Sidebar Tabs -->
        <TabControl Classes="sidebar"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

            <!-- ═══ Tab 1: メイン ═══ -->
            <!-- アイコンは Material Design Icons (Apache 2.0)。 PathIcon は親 TabItem.Foreground を継承して
                 hover / selected 状態に自動追従。 サイズ 16x16 + Spacing 10 で控えめにテキスト主導のレイアウト。 -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
                        <TextBlock Text="メイン" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="リアルタイム字幕翻訳" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="ゲームや動画の音声をリアルタイムで翻訳字幕に変換します"
                                       FontSize="12" Foreground="{DynamicResource Brush.FG2}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- ステータス + 開始/停止 (最上部に集約)。 コンテンツが増えたので、 操作の起点である
                             ステータス & 開始停止を一番上にまとめてすぐ押せるようにする。 -->
                        <HeaderedContentControl Header="ステータス" Margin="0,0,0,4">
                            <StackPanel>
                                <!-- 開始 / 停止 ボタン (ステータスエリア内に配置) -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <Button Content="開始" Command="{Binding StartCommand}"
                                            IsEnabled="{Binding CanStart}" Width="140"/>
                                    <Button Content="停止" Command="{Binding StopCommand}"
                                            IsEnabled="{Binding IsRunning}" Width="140" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="処理遅延: " FontSize="12"
                                               Foreground="{DynamicResource Brush.FG2}"/>
                                    <TextBlock Text="{Binding ProcessingLatency, StringFormat=\{0:F0\}ms}"
                                               FontSize="12"/>
                                    <TextBlock Text="  |  翻訳遅延: " Margin="16,0,0,0" FontSize="12"
                                               Foreground="{DynamicResource Brush.FG2}"/>
                                    <TextBlock Text="{Binding TranslationLatency, StringFormat=\{0:F0\}ms}"
                                               FontSize="12"/>
                                </StackPanel>
                                <!-- セッションの推定 token / コスト / VAD 節約 (案 G 見える化) -->
                                <TextBlock Text="{Binding CumulativeStatsText}"
                                           IsVisible="{Binding CumulativeStatsText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="11" Margin="0,4,0,0"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- Process Selection -->
                        <HeaderedContentControl Header="対象アプリケーション">
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox Grid.Column="0" ItemsSource="{Binding Processes}"
                                          SelectedItem="{Binding SelectedProcess}"
                                          PlaceholderText="プロセスを選択"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="1" Content="更新"
                                        Command="{Binding RefreshProcessesCommand}"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Output Language (メインに移動 — ユーザーが翻訳開始前に頻繁に切替える設定なのでメインに置く) -->
                        <HeaderedContentControl Header="出力言語 (翻訳先)">
                            <ComboBox ItemsSource="{Binding SettingsVM.OutputLanguageOptions}"
                                      SelectedItem="{Binding SettingsVM.SelectedOutputLanguage, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:OutputLanguageOption">
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </HeaderedContentControl>

                        <!-- 入力プリプロセス (音声処理タブから移動): 選択プロセスの音量をリアルタイム表示し、 開始前にゲイン調整できる。
                             DataContext を SettingsVM に束ねるので配下の binding は vm:SettingsViewModel。 -->
                        <StackPanel DataContext="{Binding SettingsVM}" x:DataType="vm:SettingsViewModel" Margin="0,0,0,0">
                        <!-- ═══ 入力プリプロセス DSP (v1.0.30 新規) ═══ -->
                        <TextBlock Text="入力プリプロセス" FontSize="16" FontWeight="Bold" Margin="0,24,0,8"/>
                        <TextBlock Text="ゲーム音量が小さいときや遠くの声を拾えないときに、 入力音声を底上げ・整形する DSP チェーンです。 全部オフ・ゲイン 0 dB で現状動作と同じ (完全 bypass)。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <HeaderedContentControl Header="入力ゲイン (Input Gain)">
                            <StackPanel>
                                <!-- OBS 風レベルメーター (ゲイン適用後のピーク)。 緑→黄→赤の固定ゾーン背景を、 現在レベルより右側を半透明マスクで覆って表現する。 -->
                                <Border Height="14" CornerRadius="3" ClipToBounds="True" Margin="0,0,0,2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                            <GradientStop Offset="0.0"  Color="#2ECC40"/>
                                            <GradientStop Offset="0.65" Color="#2ECC40"/>
                                            <GradientStop Offset="0.80" Color="#FFDC00"/>
                                            <GradientStop Offset="0.90" Color="#FF851B"/>
                                            <GradientStop Offset="1.0"  Color="#FF4136"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border HorizontalAlignment="Right" Background="#D00F1419">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource LevelMeterMaskWidthConverter}">
                                                <Binding Path="InputLevelNorm"/>
                                                <Binding Path="Bounds.Width" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Border>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Text="レベル (ゲイン適用後)" FontSize="10" Foreground="{DynamicResource Brush.FG2}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InputLevelText}" FontSize="10" Foreground="{DynamicResource Brush.FG2}"/>
                                </Grid>

                                <!-- ゲインフェーダー: 左=小さく / 右=大きく の絶対フェーダー (中央が 0 dB)。 OBS 風。 -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Slider Grid.Column="0"
                                            Minimum="-24" Maximum="24"
                                            Value="{Binding InputGainDb, Mode=TwoWay}"
                                            TickFrequency="6" TickPlacement="BottomRight"
                                            VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="0 dB"
                                            Command="{Binding ResetInputGainCommand}"
                                            ToolTip.Tip="ゲインを 0 dB (等倍) に戻す"
                                            VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                                    <TextBlock Grid.Column="0" Text="小さく" FontSize="10" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding InputGainDb, StringFormat='{}{0:+0;-0;0} dB'}"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.FG}"/>
                                    <TextBlock Grid.Column="2" Text="大きく" FontSize="10" Foreground="{DynamicResource Brush.FG2}" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="左へ動かすほど小さく、 右へ動かすほど大きくなります (中央＝0 dB / 等倍、 範囲 -24〜+24 dB)。 上のメーターを見ながら、 ピークが右端の赤 (0 dBFS = クリップ) に張り付かないよう調整してください。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>
                        </StackPanel>

                        <!-- API キー未入力時の警告（IsApiKeyConfigured=false の時のみ表示） -->
                        <Border IsVisible="{Binding !IsApiKeyConfigured}"
                                Background="#33FFA500"
                                BorderBrush="#FFFFA500"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⚠" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                    <Run Text="OpenAI API キーが未設定です。"/>
                                    <LineBreak/>
                                    <Run Text="上の「API設定」タブを開いて API キーを入力してください。" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 通知バナー: API 致命エラー (赤/❌「OpenAI API エラー」) と お知らせ (橙/📢「お知らせ」) を
                             ErrorBannerTitle / ErrorBannerIcon / ErrorBannerBackground / ErrorBannerBorderBrush で出し分ける。
                             デバッグ録音 ON / VAD fallback / 設定矯正 は「エラー」ではないので橙のお知らせ側に出す。 -->
                        <Border IsVisible="{Binding IsErrorBannerVisible}"
                                Background="{Binding ErrorBannerBackground}"
                                BorderBrush="{Binding ErrorBannerBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,8,0,0">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding ErrorBannerIcon}" FontSize="16"
                                           VerticalAlignment="Top" Margin="0,2,8,0"/>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding ErrorBannerTitle}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding ErrorBannerMessage}"
                                               TextWrapping="Wrap" FontSize="12"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="✕"
                                        Command="{Binding DismissErrorBannerCommand}"
                                        VerticalAlignment="Top" Padding="6,2"
                                        FontSize="11" Background="Transparent"
                                        ToolTip.Tip="バナーを閉じる"/>
                            </Grid>
                        </Border>


                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 2: API設定 ═══ -->
            <TabItem x:DataType="vm:MainViewModel">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M22,18V22H18V19H15V16H12L9.74,13.74C9.19,13.91 8.61,14 8,14A6,6 0 0,1 2,8A6,6 0 0,1 8,2A6,6 0 0,1 14,8C14,8.61 13.91,9.19 13.74,9.74L22,18M7,5A2,2 0 0,0 5,7A2,2 0 0,0 7,9A2,2 0 0,0 9,7A2,2 0 0,0 7,5Z"/>
                        <TextBlock Text="API設定" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SettingsVM}">
                    <StackPanel Margin="0,0,0,16" x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="OpenAI API設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- API Key -->
                        <HeaderedContentControl Header="APIキー">
                            <StackPanel>
                                <TextBox Text="{Binding ApiKey, Mode=TwoWay}"
                                         PasswordChar="*"
                                         PlaceholderText="sk-..."
                                         Margin="0,0,0,10"/>
                                <Button Content="接続テスト"
                                        Command="{Binding TestApiConnectionCommand}"
                                        IsEnabled="{Binding IsTestingApi, Converter={StaticResource InverseBoolConverter}}"
                                        Margin="0,0,0,8"/>
                                <TextBox Text="{Binding ApiTestResult, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="13"
                                         IsVisible="{Binding ApiTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- ╔═══════════════════════════════════════════════════════════════════════════╗ -->
                        <!-- ║  OpenAI APIキー取得方法ガイド (初心者向け、 5 ステップ + 注意事項)          ║ -->
                        <!-- ╚═══════════════════════════════════════════════════════════════════════════╝ -->
                        <TextBlock Text="🔑 APIキーの取得方法 (初めての方へ)"
                                   FontSize="18" FontWeight="Bold" Margin="0,28,0,4"/>
                        <TextBlock Text="OpenAI のサイトでアカウントを作って、 支払い方法を登録して、 APIキーを発行する流れだよ〜 全部で 5〜10 分くらい💕"
                                   FontSize="12" Foreground="{DynamicResource Brush.FG2}"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <!-- ステップ 1: アカウント作成 -->
                        <Border Padding="14,12" Margin="0,0,0,8"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid ColumnDefinitions="42,*">
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="#3366CCFF" BorderBrush="#FF66CCFF" BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="1" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="OpenAI アカウントを作る 👤"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="①" FontWeight="Bold"/>
                                        <Run Text=" ブラウザで OpenAI のサイトを開く"/>
                                    </TextBlock>
                                    <Border Padding="8,4" Margin="0,4,0,6" CornerRadius="4"
                                            Background="{DynamicResource Brush.Border}"
                                            HorizontalAlignment="Left">
                                        <SelectableTextBlock Text="https://platform.openai.com/signup"
                                                              FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                                    </Border>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="②" FontWeight="Bold"/>
                                        <Run Text=" 「Sign up」ボタンから登録 (メールアドレス または Google / Microsoft / Apple アカウントが使えるよ)"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,4,0,0">
                                        <Run Text="③" FontWeight="Bold"/>
                                        <Run Text=" メール認証 + 電話番号認証 (SMS) を済ませる"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ステップ 2: 支払い方法登録 -->
                        <Border Padding="14,12" Margin="0,0,0,8"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid ColumnDefinitions="42,*">
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="#33FFAA33" BorderBrush="#FFFFAA33" BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="2" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="支払い方法を登録 (クレジットカード) 💳"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="①" FontWeight="Bold"/>
                                        <Run Text=" 課金設定ページを開く"/>
                                    </TextBlock>
                                    <Border Padding="8,4" Margin="0,4,0,6" CornerRadius="4"
                                            Background="{DynamicResource Brush.Border}"
                                            HorizontalAlignment="Left">
                                        <SelectableTextBlock Text="https://platform.openai.com/settings/organization/billing/overview"
                                                              FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                                    </Border>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="②" FontWeight="Bold"/>
                                        <Run Text=" 「Add payment method」でクレジットカード情報を登録"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,4,0,0">
                                        <Run Text="③" FontWeight="Bold"/>
                                        <Run Text=" 「Add to credit balance」から "/>
                                        <Run Text="$5 〜 $10" FontWeight="Bold"/>
                                        <Run Text=" くらい事前チャージ (試しに少額からで OK)"/>
                                    </TextBlock>
                                    <Border Padding="8,6" Margin="0,8,0,0" CornerRadius="6"
                                            Background="#1A66CCFF">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16">
                                            <Run Text="💡 " /><Run Text="OpenAI は前払い方式なので、 残高がなくなったら自動的に翻訳が止まるよ (使いすぎ防止)。 不安なら少額から始めてね。"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ステップ 3: APIキー発行 -->
                        <Border Padding="14,12" Margin="0,0,0,8"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid ColumnDefinitions="42,*">
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="#33CC66FF" BorderBrush="#FFCC66FF" BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="3" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="APIキーを発行する 🔑"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="①" FontWeight="Bold"/>
                                        <Run Text=" APIキー管理ページを開く"/>
                                    </TextBlock>
                                    <Border Padding="8,4" Margin="0,4,0,6" CornerRadius="4"
                                            Background="{DynamicResource Brush.Border}"
                                            HorizontalAlignment="Left">
                                        <SelectableTextBlock Text="https://platform.openai.com/api-keys"
                                                              FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                                    </Border>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text="②" FontWeight="Bold"/>
                                        <Run Text=" 緑の「+ Create new secret key」ボタンをクリック"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,4,0,0">
                                        <Run Text="③" FontWeight="Bold"/>
                                        <Run Text=" Name に分かりやすい名前 (例: "/>
                                        <Run Text="RealTimeTranslator" FontStyle="Italic"/>
                                        <Run Text=")、 Permissions は "/>
                                        <Run Text="All" FontWeight="Bold"/>
                                        <Run Text=" のままで OK"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,4,0,0">
                                        <Run Text="④" FontWeight="Bold"/>
                                        <Run Text=" 「Create secret key」を押すと "/>
                                        <Run Text="sk-..." FontFamily="Consolas,Menlo,monospace" FontWeight="Bold"/>
                                        <Run Text=" で始まる長い文字列が表示される → 「Copy」ボタンでコピー"/>
                                    </TextBlock>
                                    <Border Padding="8,6" Margin="0,8,0,0" CornerRadius="6"
                                            Background="#33FF6666">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16">
                                            <Run Text="⚠️ " FontWeight="Bold"/>
                                            <Run Text="この画面を閉じるとキーは "/>
                                            <Run Text="二度と見られない" FontWeight="Bold"/>
                                            <Run Text=" よ！ 必ずコピーしてから閉じてね。 もし忘れちゃったらまた作り直し OK だよ💦"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ステップ 4: 貼り付け -->
                        <Border Padding="14,12" Margin="0,0,0,8"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid ColumnDefinitions="42,*">
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="#3366FF99" BorderBrush="#FF66FF99" BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="4" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="このアプリに貼り付ける 📋"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text=" 上の「APIキー」入力欄に "/>
                                        <Run Text="Ctrl+V" FontFamily="Consolas,Menlo,monospace" FontWeight="Bold"/>
                                        <Run Text=" で貼り付けるだけ✨ "/>
                                        <Run Text="sk-..." FontFamily="Consolas,Menlo,monospace"/>
                                        <Run Text=" で始まる長い文字列が入れば OK。 入力欄は "/>
                                        <Run Text="*" FontFamily="Consolas,Menlo,monospace"/>
                                        <Run Text=" でマスクされて表示されるよ。"/>
                                    </TextBlock>
                                    <Border Padding="8,6" Margin="0,8,0,0" CornerRadius="6"
                                            Background="#1A66FF99">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16">
                                            <Run Text="🔒 " /><Run Text="APIキーは Windows の DPAPI で暗号化して保存されるから、 別ユーザー / 別 PC からは復号できないよ。 安心して保存してね💕"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ステップ 5: 接続テスト -->
                        <Border Padding="14,12" Margin="0,0,0,16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid ColumnDefinitions="42,*">
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="#33FF99CC" BorderBrush="#FFFF99CC" BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="5" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="接続テストで確認 ✅"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                        <Run Text=" 上の「接続テスト」ボタンを押す → 「接続成功！APIキーは有効です。」って出れば全部 OK🎉"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18" Margin="0,4,0,0">
                                        <Run Text=" もしエラーが出たら、 キーをコピペし直す or もう一度キー発行からやり直してみてね。"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 課金の目安 -->
                        <Border Padding="14,12" Margin="0,4,0,0"
                                Background="#1AFFAA33"
                                BorderBrush="#80FFAA33"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                                    <TextBlock Text="💰" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="課金の目安" FontSize="13" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18">
                                    <Run Text="このアプリは話している間だけ OpenAI に音声を送るよ (VAD 機能)。 現在の翻訳モデルでの目安:"/>
                                </TextBlock>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                    <TextBlock Grid.Column="0" Text="• gpt-realtime-translate" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="~ $2 / 時間" FontSize="13" FontWeight="Bold"
                                               Foreground="#66CC66"/>
                                </Grid>
                                <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16" Margin="0,8,0,0"
                                           Foreground="{DynamicResource Brush.FG2}">
                                    <Run Text="さらに節約したいときは "/>
                                    <Run Text="「音声処理」タブの VAD プリセット" FontStyle="Italic"/>
                                    <Run Text=" で無音時間を削るのが効果的🌸"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16" Margin="0,10,0,4"
                                           Foreground="{DynamicResource Brush.FG2}">
                                    <Run Text="📊 "/>
                                    <Run Text="実際の使用量・残高・請求履歴は OpenAI ダッシュボードで確認できるよ:"/>
                                </TextBlock>
                                <Border Padding="8,4" CornerRadius="4"
                                        Background="{DynamicResource Brush.Border}"
                                        HorizontalAlignment="Left">
                                    <SelectableTextBlock Text="https://platform.openai.com/usage"
                                                          FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 3: 音声処理 (VAD + 自動Pause) ═══ -->
            <TabItem x:DataType="vm:MainViewModel">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M9,3V21H7V3H9M5,5V19H3V5H5M13,7V17H11V7H13M17,9V15H15V9H17M21,11V13H19V11H21Z"/>
                        <TextBlock Text="音声処理" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SettingsVM}">
                    <StackPanel Margin="0,0,0,16" x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="音声検出 (VAD) 設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="BGM や効果音だけのシーンで OpenAI への送信を抑制し、 token 浪費を防ぎます。"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <HeaderedContentControl Header="VAD を有効にする">
                            <CheckBox IsChecked="{Binding EnableVad, Mode=TwoWay}"
                                      Content="人の声と判定された区間だけ OpenAI に送る (推奨)"/>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="感度プリセット" Margin="0,16,0,0">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding VadPresetOptions}"
                                          SelectedItem="{Binding SelectedVadPreset, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:VadPresetOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="「ふつう」で OK。 短い発話を取りこぼすなら「頭と尻尾を取りこぼさない」、 ゲーム配信を長時間流すなら「ガッツリ節約」を選んでね。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- カスタム選択時のみ表示する詳細スライダー (上級者向け) -->
                        <Border IsVisible="{Binding IsVadPresetCustom}"
                                Margin="0,12,0,0" Padding="12"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="🛠 カスタム詳細" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Text="検出しきい値 (Silero VAD speech probability)" FontSize="12" Margin="0,4,0,2"/>
                                <Slider Minimum="0.1" Maximum="0.9" Value="{Binding VadThreshold, Mode=TwoWay}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding VadThreshold, StringFormat='現在: {0:F2} (本アプリ既定 0.40、 Silero VAD 公式推奨 0.50、 上げるほど判定が厳しくなり送信量減)'}"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}" Margin="0,0,0,8"/>

                                <TextBlock Text="プリロール時間 (ms) — 発話冒頭の取りこぼし防止" FontSize="12" Margin="0,4,0,2"/>
                                <NumericUpDown Value="{Binding VadPreRollMs, Mode=TwoWay}"
                                               Minimum="0" Maximum="2000" Increment="50" Margin="0,0,0,8"/>

                                <TextBlock Text="ハングオーバー時間 (ms) — 発話末尾の切れ防止" FontSize="12" Margin="0,4,0,2"/>
                                <NumericUpDown Value="{Binding VadHangoverMs, Mode=TwoWay}"
                                               Minimum="0" Maximum="2000" Increment="50"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="自動 Pause 保険" FontSize="16" FontWeight="Bold" Margin="0,24,0,8"/>

                        <HeaderedContentControl Header="連続無音時間で自動停止">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding AutoPauseOptions}"
                                          SelectedItem="{Binding SelectedAutoPauseOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AutoPauseOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="この時間ずっと speech が検出されないとキャプチャを自動停止します。 席を離れた間の token 垂れ流し事故防止用。 VAD 有効時のみ機能します。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>


                        <!-- ═══ デバッグ録音 (送信前 PCM16 → WAV) ═══ -->
                        <TextBlock Text="デバッグ" FontSize="16" FontWeight="Bold" Margin="0,24,0,8"/>

                        <HeaderedContentControl Header="送信音声を WAV 録音">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding DebugRecordSentAudio, Mode=TwoWay}"
                                          Content="OpenAI に送信する PCM16 (24kHz / Mono) を WAV に保存する"/>
                                <TextBlock Text="VAD ゲート通過後・サイレンス padding 含めて、 送信を試みたバイト列 (NW 詰まりで DropOldest された分も含む) を記録します。 セッションごとに 1 ファイル (SentAudio_YYYYMMDD_HHmmss_xxxx.wav)。 24kHz / Mono / PCM16 で 1 時間あたり約 170 MB のディスクを消費するため、 必要なときだけ ON にしてください。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,4,0,8"/>
                                <Button Content="録音フォルダを開く"
                                        Command="{Binding OpenDebugFolderCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 4: 表示設定 ═══ -->
            <TabItem x:DataType="vm:MainViewModel">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M17.5,12A1.5,1.5 0 0,1 16,10.5A1.5,1.5 0 0,1 17.5,9A1.5,1.5 0 0,1 19,10.5A1.5,1.5 0 0,1 17.5,12M14.5,8A1.5,1.5 0 0,1 13,6.5A1.5,1.5 0 0,1 14.5,5A1.5,1.5 0 0,1 16,6.5A1.5,1.5 0 0,1 14.5,8M9.5,8A1.5,1.5 0 0,1 8,6.5A1.5,1.5 0 0,1 9.5,5A1.5,1.5 0 0,1 11,6.5A1.5,1.5 0 0,1 9.5,8M6.5,12A1.5,1.5 0 0,1 5,10.5A1.5,1.5 0 0,1 6.5,9A1.5,1.5 0 0,1 8,10.5A1.5,1.5 0 0,1 6.5,12M12,3A9,9 0 0,0 3,12A9,9 0 0,0 12,21A1.5,1.5 0 0,0 13.5,19.5C13.5,19.11 13.35,18.76 13.11,18.5C12.88,18.23 12.73,17.88 12.73,17.5A1.5,1.5 0 0,1 14.23,16H16A5,5 0 0,0 21,11C21,6.58 16.97,3 12,3Z"/>
                        <TextBlock Text="表示設定" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SettingsVM}">
                    <StackPanel Margin="0,0,0,16" x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="オーバーレイ表示設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- 字幕オーバーレイ表示 ON/OFF (v1.0.41) -->
                        <HeaderedContentControl Header="字幕オーバーレイ">
                            <StackPanel>
                                <ToggleSwitch IsChecked="{Binding ShowSubtitleOverlay, Mode=TwoWay}"
                                              OnContent="表示する" OffContent="非表示"/>
                                <TextBlock Text="画面に重ねる字幕オーバーレイの表示/非表示を切り替えます。 非表示にしても翻訳処理は続くので、 「翻訳ログ」タブで履歴を読めます。 字幕を画面に出したくない人・ ログだけ見たい人向けです。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- Font -->
                        <HeaderedContentControl Header="フォント">
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto">
                                <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                          ItemsSource="{Binding FontFamilies}"
                                          SelectedItem="{Binding SelectedFontFamily, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="サイズ"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding FontSizes}"
                                          SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=\{0\}px}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="太さ"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding FontWeightOptions}"
                                          SelectedItem="{Binding SelectedFontWeightOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FontWeightOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Colors -->
                        <HeaderedContentControl Header="字幕カラー">
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="仮字幕色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding TextColorOptions}"
                                          SelectedItem="{Binding SelectedPartialTextColorOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="確定字幕色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding TextColorOptions}"
                                          SelectedItem="{Binding SelectedFinalTextColorOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="背景色"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding BackgroundColorBaseOptions}"
                                          SelectedItem="{Binding SelectedBackgroundColorBaseOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,6">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ColorOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="背景の濃さ"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{Binding OpacityOptions}"
                                          SelectedItem="{Binding SelectedBackgroundOpacityOption, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" Margin="0,6,0,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:OpacityOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- Max Lines + Display Duration -->
                        <HeaderedContentControl Header="表示">
                            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="最大行数 (確定+未確定の合計)"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding MaxLinesList}"
                                          SelectedItem="{Binding SelectedMaxLines, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,2">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="画面に同時に並ぶ行数の上限。 確定済み字幕 + 翻訳中の未確定字幕の合計をこの行数で制限します。"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.FG2}" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="確定字幕の表示時間"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.FG2}" FontSize="13"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding DisplayDurations}"
                                          SelectedItem="{Binding SelectedDisplayDuration, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,2">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat=\{0\} 秒}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="確定済み字幕が画面から消えるまでの秒数。 未確定字幕は新しい音声が来るまで表示され続けます。"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.FG2}" Margin="0,0,0,0"/>
                            </Grid>
                        </HeaderedContentControl>

                        <!-- 翻訳字幕位置調整 (v1.0.41) -->
                        <HeaderedContentControl Header="翻訳字幕位置調整">
                            <StackPanel>
                                <TextBlock Text="字幕を表示する位置を画面上の好きな場所へ移動できます。 「位置を調整」を押すとオーバーレイにサンプル字幕が出るので、 マウスでドラッグして動かし、 オーバーレイ上の「確定して保存」で固定します。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="🎯 位置を調整 (編集開始)"
                                            Command="{Binding BeginSubtitlePositionEditCommand}"
                                            IsEnabled="{Binding !IsSubtitlePositionEditMode}"/>
                                    <Button Content="↺ 位置をリセット"
                                            Command="{Binding ResetSubtitlePositionCommand}"
                                            ToolTip.Tip="字幕位置をデフォルト (下部中央) に戻す"/>
                                </StackPanel>
                                <TextBlock Text="編集中はオーバーレイ上部のツールバーで「確定 / リセット / キャンセル」できます。"
                                           IsVisible="{Binding IsSubtitlePositionEditMode}"
                                           FontSize="11" Foreground="#FF4FC3F7"
                                           TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!-- 翻訳ログの保持期間 -->
                        <HeaderedContentControl Header="翻訳ログの保持期間">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding TranslationLogRetentionOptions}"
                                          SelectedItem="{Binding SelectedTranslationLogRetention, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TranslationLogRetentionOption">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="「翻訳ログ」タブで閲覧できる翻訳履歴を、 何日前まで残すかを指定します。 「無制限」だと自動削除されません (ゴミ箱と同じく手動削除のみ)。 設定変更は次回起動時に反映されます。"
                                           FontSize="11" Foreground="{DynamicResource Brush.FG2}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 5: 翻訳ログ ═══ -->
            <TabItem x:DataType="vm:MainViewModel">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.89,15.89L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3"/>
                        <TextBlock Text="翻訳ログ" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid DataContext="{Binding TranslationLogVM}"
                      x:DataType="vm:TranslationLogViewModel"
                      RowDefinitions="*,Auto">

                    <!-- 翻訳ログ本体: ADV ゲーム会話ログ風の縦並びカード -->
                    <!-- Discord 風オートスクロール: 最下部追従 + 上スクロール中は追従停止 (MainWindow.axaml.cs)。
                         イベントハンドラは DataContext (TranslationLogViewModel) ではなく code-behind の MainWindow に解決される。 -->
                    <ScrollViewer Grid.Row="0" x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding !IsEmpty}"
                                  Loaded="OnLogScrollViewerLoaded"
                                  ScrollChanged="OnLogScrollChanged">
                        <ItemsControl ItemsSource="{Binding Entries}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TranslationLogEntry">
                                    <Border Margin="0,0,0,10" Padding="14,10"
                                            Background="{DynamicResource Brush.Container}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1" CornerRadius="10">
                                        <StackPanel>
                                            <!-- ヘッダー: 日時 / 言語 / プロセス / セッション ID -->
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding FormattedTimestamp}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.FG2}"/>
                                                <TextBlock Text="{Binding Language, StringFormat='[{0}]'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.FG2}"/>
                                                <TextBlock Text="{Binding ProcessName}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.FG2}"
                                                           IsVisible="{Binding ProcessName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Text="{Binding SessionId, StringFormat='#{0}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.FG2}"
                                                           IsVisible="{Binding SessionId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>
                                            <!-- 本文: 翻訳テキスト (大きめフォントで読みやすく) -->
                                            <!-- SelectableTextBlock で範囲選択 + コピー可能にする (Avalonia 12 の TextBlock 自体には selection なし) -->
                                            <SelectableTextBlock Text="{Binding Text}"
                                                                  FontSize="15" TextWrapping="Wrap"
                                                                  LineHeight="22"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 空状態 placeholder -->
                    <StackPanel Grid.Row="0"
                                IsVisible="{Binding IsEmpty}"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="まだ翻訳ログがありません"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Brush.FG2}"/>
                        <TextBlock Text="「メイン」タブで翻訳を開始すると、 確定字幕がここに記録されます。"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- 下部アクションバー: フォルダを開く + すべて削除 -->
                    <Border Grid.Row="1" Padding="0,8,0,0"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding OpenTranslationLogsFolderCommand}"
                                    Content="保存フォルダを開く" FontSize="12"/>
                            <Button Command="{Binding ClearAllCommand}"
                                    Content="すべて削除" FontSize="12"
                                    IsEnabled="{Binding !IsEmpty}"/>
                            <!-- 最新へ移動: 上にスクロールして追従が外れている間だけ有効 (IsEnabled は code-behind が制御)。
                                 Click は code-behind の MainWindow.OnJumpToLatestClick に解決される。 -->
                            <Button x:Name="JumpToLatestButton"
                                    Click="OnJumpToLatestClick"
                                    Content="↓ 最新へ" FontSize="12"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ Tab 6: バージョン ═══ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Width="16" Height="16" VerticalAlignment="Center"
                                  Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"/>
                        <TextBlock Text="バージョン" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,0,8,12">
                        <TextBlock Margin="4,0,0,4" FontSize="28" FontWeight="Bold"
                                   Text="リアルタイム字幕翻訳"/>
                        <TextBlock Margin="4,0,0,20" FontSize="14"
                                   Foreground="{DynamicResource Brush.FG2}"
                                   Text="ゲームや動画の音声をリアルタイムで翻訳字幕に変換するデスクトップアプリ"/>

                        <!-- バージョン情報パネル -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Margin="0,0,12,0" VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="バージョン"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           VerticalAlignment="Center" FontSize="13"
                                           Text="{Binding VersionText}"/>
                                <Button Grid.Row="0" Grid.Column="2"
                                        Command="{Binding CheckForUpdateCommand}"
                                        Content="更新の確認" FontSize="12"
                                        IsEnabled="{Binding !IsCheckingUpdate}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                           Margin="0,6,0,0" FontSize="12"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           IsVisible="{Binding UpdateStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Text="{Binding UpdateStatusText}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- トラブルシュート: ログ / 設定フォルダ (rere P2 F-2 修正) -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="トラブルシュート用: ログ / 設定フォルダをエクスプローラで開きます。"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding OpenLogsFolderCommand}"
                                            Content="ログフォルダを開く" FontSize="12"/>
                                    <Button Command="{Binding OpenSettingsFolderCommand}"
                                            Content="設定フォルダを開く" FontSize="12"/>
                                </StackPanel>
                                <!-- /rere #F-002: ログには翻訳テキストの先頭 40 文字スニペットが含まれる。
                                     GitHub Issues 等への共有前にユーザーへ警告を表示する。 -->
                                <TextBlock Margin="0,10,0,0" FontSize="11"
                                           Foreground="{DynamicResource Brush.Error}"
                                           Text="⚠️ ログには翻訳テキストの先頭 40 文字が含まれます。 GitHub Issues 等で共有する前に内容を確認してください。"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ご意見・ご要望 -->
                        <Border Margin="0,0,0,12" Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="不具合報告・ご要望は GitHub Issues へどうぞ。"
                                           TextWrapping="Wrap"/>
                                <Button Command="{Binding OpenFeedbackLinkCommand}"
                                        Content="GitHub Issues を開く" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- コピーライト -->
                        <Border Padding="16"
                                Background="{DynamicResource Brush.Container}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6" FontSize="13" FontWeight="SemiBold"
                                           Text="コピーライト"/>
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource Brush.FG2}"
                                           Text="{Binding CopyrightText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
    </Panel>
</Window>
