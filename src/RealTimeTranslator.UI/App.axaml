<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RealTimeTranslator.UI.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Resources/Themes.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI, Microsoft YaHei, Malgun Gothic, Noto Sans CJK, sans-serif" />
        </Style>

        <Style Selector="TabControl.sidebar">
            <Setter Property="TabStripPlacement" Value="Left" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate TargetType="TabControl">
                    <Grid ColumnDefinitions="160,*">
                        <Border
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="6"
                            Background="{DynamicResource Brush.Container}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            BoxShadow="0 8 24 0 #18000000, 0 2 6 0 #10000000, inset 0 1 0 0 #30FFFFFF"
                            CornerRadius="14">
                            <ItemsPresenter Name="PART_ItemsPresenter">
                                <ItemsPresenter.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel HorizontalAlignment="Stretch" />
                                    </ItemsPanelTemplate>
                                </ItemsPresenter.ItemsPanel>
                            </ItemsPresenter>
                        </Border>
                        <!-- MaxWidth: ウィンドウ最大化・大幅リサイズ時にコンテンツが横へ間延びするのを防ぐ。
                             通常サイズ (750px 窓) では制約に当たらず全幅、 広げたときだけ 960px で頭打ち + 中央寄せ。
                             HorizontalAlignment は Stretch のままにして「Left 指定で幅が中身サイズに縮む」事故を回避する。 -->
                        <ContentPresenter
                            Name="PART_SelectedContentHost"
                            Grid.Column="1"
                            Margin="0"
                            MaxWidth="960"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding SelectedContent}"
                            ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabControl.sidebar > TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.FG1}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TabControl.sidebar > TabItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TabControl.sidebar > TabItem /template/ Border#PART_LayoutRoot">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="TabControl.sidebar > TabItem /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="TabControl.sidebar > TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource Brush.SidebarHover}" />
        </Style>

        <Style Selector="TabControl.sidebar > TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource Brush.FG1}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="TabControl.sidebar > TabItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource Brush.SidebarSelected}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="HeaderedContentControl">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Margin="0,0,0,12"
                        Padding="16"
                        Background="{DynamicResource Brush.Container}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.FG2}"
                                Text="{TemplateBinding Header}" />
                            <ContentPresenter Name="PART_ContentPresenter" Content="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </Application.Styles>
</Application>
