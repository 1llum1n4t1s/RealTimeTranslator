<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
    <ApplicationIcon>..\..\icon\app.ico</ApplicationIcon>
    <InvariantGlobalization>false</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\RealTimeTranslator.Core\RealTimeTranslator.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.2" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.2" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.2" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.2" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.7" />
    <PackageReference Include="Velopack" Version="0.0.1298" />
  </ItemGroup>

  <ItemGroup>
    <None Update="settings.default.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
  </ItemGroup>

  <!-- Build 時: 出力先に settings.json が無ければ settings.default.json をコピーして初期化する -->
  <Target Name="CopyDefaultSettingsAfterBuild" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)settings.default.json"
          DestinationFiles="$(OutputPath)settings.json"
          Condition="Exists('$(OutputPath)settings.default.json') and !Exists('$(OutputPath)settings.json')" />
  </Target>

  <!-- Publish 時: 配布先にも同様に settings.json を生成する（Velopack 配布版で初期設定が無い問題を防ぐ） -->
  <Target Name="CopyDefaultSettingsAfterPublish" AfterTargets="Publish">
    <Copy SourceFiles="$(PublishDir)settings.default.json"
          DestinationFiles="$(PublishDir)settings.json"
          Condition="Exists('$(PublishDir)settings.default.json') and !Exists('$(PublishDir)settings.json')" />
  </Target>

</Project>
